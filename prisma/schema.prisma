generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  currency    String   @default("USD")
  stock       Int      @default(0)
  images      String   @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model AuthSession {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
}
