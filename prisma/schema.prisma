generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("user")
  createdAt    DateTime  @default(now())
  products     Product[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  sku         String
  stock       Int
  imageUrl    String   @default("")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  creator     User     @relation(fields: [createdBy], references: [id])

  @@index([sku])
  @@index([createdBy])
}
